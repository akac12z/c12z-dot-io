---
import MainLayout from "@layouts/MainLayout.astro";

import { PAGES } from "@/global/pages-info.ts";

import ProjectPage from "@/features/projects/components/ProjectPage.astro";
import PagesSEO from "@/components/common/seo/PagesSEO.astro";

import { projectPageKeywords } from "@/features/projects/seo/projectPage.keywords";
---

<MainLayout>
	<PagesSEO
		slot="head"
		pageTitle={PAGES.projects.title}
		pageDescription={PAGES.projects.description}
		ogImage={PAGES.projects.ogImage}
		ogImageAlt={PAGES.projects.ogImageAlt}
		pageKeywords={projectPageKeywords}
	/>
	<ProjectPage />
</MainLayout>
