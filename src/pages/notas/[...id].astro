---
import { getCollection, render, type CollectionEntry } from "astro:content";

import MainLayout from "@layouts/MainLayout.astro";

import GoBackInTop from "@/components/common/ui/buttons/GoBackInTop.astro";

import styles from "@/features/notes/components/notes.module.css";
import { convertDateToISO8601 } from "@utils/validating-date.ts";
import { formatNoteDate } from "@/features/notes/data/format-note-date.ts";
import SourceBadges from "@/features/notes/components/SourceBadges.astro";
import NotesSEO from "@/features/notes/seo/NotesSEO.content.astro";

interface Props {
	entry: CollectionEntry<"notes">;
}

export async function getStaticPaths() {
	const notes = await getCollection("notes");

	return notes.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { title, publishDate, sources } = entry.data;

const { Content } = await render(entry);
---

<MainLayout>
	<NotesSEO
		slot="head"
		entry={entry}
	/>
	<article class={styles.note}>
		<GoBackInTop
			headPage="/notas"
			title="ir a la página de notas"
		/>

		<header class={styles.noteIntro}>
			<p class={styles.meta}>
				<time datetime={convertDateToISO8601(publishDate)}>
					{formatNoteDate(publishDate)}
				</time>
				<span class={styles.pill}>Nota</span>
			</p>
			<h1 transition:name={`${entry.id}-note-title`}>{title}</h1>
		</header>

		<section class="lettering">
			<Content />
		</section>

		{
			sources.length > 0 && (
				<footer class={styles.sourcesFooter}>
					<p class={styles.sourcesLabel}>Fuentes</p>
					<SourceBadges sources={sources} />
				</footer>
			)
		}
	</article>
</MainLayout>
