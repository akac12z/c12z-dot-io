---
import MainLayout from "@layouts/MainLayout.astro";
import { PAGES } from "@/global/pagesInfo";

import { biasKeywords } from "@/features/bias/seo/biasPage.keywords";
import BiasPage from "@/features/bias/components/BiasPage.astro";

import PagesSEO from "@/seo/PagesSEO.astro";
---

<MainLayout>
  <PagesSEO
    slot="head"
    pageTitle={PAGES.bias.title}
    pageDescription={PAGES.bias.description}
    ogImage={PAGES.bias.ogImage}
    ogImageAlt={PAGES.bias.ogImageAlt}
    pageKeywords={biasKeywords}
  />
  <BiasPage />
</MainLayout>
