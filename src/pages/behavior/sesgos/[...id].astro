---
/**
 * Neceito porner el prerender porque aun no ha salido ASTRO 5 por ende, en las páginas dinámicas necesitas esto
 */
// export const prerender = true;

import styles from "@/features/bias/components/bias.module.css"

import { getCollection, render, type CollectionEntry } from "astro:content";

import MainLayout from "@layouts/MainLayout.astro";

import BiasSEO from "@/features/bias/seo/BiasSEO.content.astro";

import BiasCategory from "@/features/bias/components/BiasCategory.astro";

import GoBackInTop from "@/components/common/ui/buttons/GoBackInTop.astro";
import TOC from "@/components/common/ui/toc/toc";

interface Props {
  entry: CollectionEntry<"bias">;
}

export async function getStaticPaths() {
  const biases = await getCollection("bias");

  return biases.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data, id } = entry;
const { biasName, publishDate, lastTimeEdited, biasQuestion, category } = data;

const { Content, headings } = await render(entry);

---

<MainLayout>
  <BiasSEO slot="head" entry={entry} />
  <section class={styles.bias}>
    <TOC client:only="react" headings={headings} title={biasName}/>
    <GoBackInTop headPage="/behavior/sesgos" title="ir a la página de behavior" />

    <article class={styles.intro}>
      <section class={styles.textAlign}>
        <h1 transition:name=`${id}-name` class={styles.biasName}>
          {biasName}
        </h1>
        <h2 class={styles.biasQuestion}>{biasQuestion}</h2>
        <section class={styles.categoriesSect}>
          {
            category.length > 1
              ? <p>Categorías del sesgo:</p>
              : <p>Categoría del sesgo:</p>
          }
          <BiasCategory category={category} />
        </section>
        <section class={styles.publish}>
          {
            lastTimeEdited && lastTimeEdited !== publishDate
              ? (
                <span class={styles.text}>Publicado: {publishDate}</span>
                <span class={styles.text}>Editado: {lastTimeEdited}</span>
              )
              : (
                <span class={styles.text}>Publicado: {publishDate}</span>
              )
          }
        </section>
      </section>
        <section class="lettering">
          <Content />
        </section>
    </article>
  </section>
</MainLayout>
