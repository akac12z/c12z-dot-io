---
/**
 * /behavior/fuentes — the drawer index. Just layout + SEO: everything the
 * page does lives in `features/sources/components/SourcesPage.astro`,
 * which is also the one that reads the content.
 */
import MainLayout from "@layouts/MainLayout.astro";
import SourcesSEO from "@/features/sources/seo/SourcesSEO.content.astro";

import { PAGES } from "@/global/pages-info";

import SourcesPage from "@/features/sources/components/SourcesPage.astro";
import { sourcesKeywords } from "@/features/sources/seo/sources.keywords";
---

<MainLayout>
	<SourcesSEO
		slot="head"
		pageTitle={PAGES.sources.title}
		pageDescription={PAGES.sources.description}
		ogImageAlt={PAGES.sources.ogImageAlt}
		pageKeywords={sourcesKeywords}
	/>
	<SourcesPage />
</MainLayout>
