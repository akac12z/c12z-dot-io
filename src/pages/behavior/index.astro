---
import MainLayout from "@layouts/MainLayout.astro";
import PagesSEO from "@/seo/PagesSEO.astro";

import { PAGES } from "@/global/pagesInfo";

import BehaviorPage from "@/features/behavior/components/BehaviorPage.astro";
import { behaviorKeywords } from "@/features/behavior/seo/behavior.keywords";
---

<MainLayout>
  <PagesSEO
    slot="head"
    pageTitle={PAGES.behavior.title}
    pageDescription={PAGES.behavior.description}
    ogImage={PAGES.behavior.ogImage}
    ogImageAlt={PAGES.behavior.ogImageAlt}
    pageKeywords={behaviorKeywords}
  />
  <BehaviorPage />
</MainLayout>
