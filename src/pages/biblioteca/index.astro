---
import { PAGES } from "@/global/pages-info";

import MainLayout from "@layouts/MainLayout.astro";
import { libraryKeywords } from "@/features/books/seo/library.keywords.ts";

import LibraryPage from "@/features/books/components/LibraryPage.astro";
import PagesSEO from "@/seo/PagesSEO.astro";
---

<MainLayout>
	<PagesSEO
		slot="head"
		pageTitle={PAGES.library.title}
		pageDescription={PAGES.library.description}
		ogImage={PAGES.library.ogImage}
		ogImageAlt={PAGES.library.ogImageAlt}
		pageKeywords={libraryKeywords}
	/>
	<LibraryPage />
</MainLayout>
