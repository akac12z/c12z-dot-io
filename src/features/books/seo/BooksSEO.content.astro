---
import { type CollectionEntry } from "astro:content";

import { SITE_DEFAULT_CONFIG } from "@/global/site-info";
import { convertDateToISO8601 } from "@/utils/validating-date.ts";

import ContentSEO from "@/seo/ContentSEO.astro";

const { entry } = Astro.props;

const library = entry as CollectionEntry<"library">;
const { data, id } = library;
const { cover, title, keywords, publishDate, titleTag } = data;

const postName = `${titleTag} - ${SITE_DEFAULT_CONFIG.title}`;

const postDescription = `Resumen e insights de ${title} - ${SITE_DEFAULT_CONFIG.title}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// OG dinámico generado en build time (src/pages/og/biblioteca/[...id].png.ts)
const ogImageSrc = new URL(`/og/biblioteca/${id}.png`, Astro.site);
const ogImageAlt = cover.alt || postName;

const publisDateInISO = convertDateToISO8601(publishDate);
const lastTimeEditedInISO = publisDateInISO;
---

<ContentSEO
	postName={postName}
	postDescription={postDescription}
	canonicalURL={canonicalURL}
	ogImageSrc={ogImageSrc}
	ogImageAlt={ogImageAlt}
	publisDateInISO={publisDateInISO}
	lastTimeEditedInISO={lastTimeEditedInISO}
	keywords={keywords}
/>
