---
import styles from "./sources-folder.module.css";

interface Props {
	sources: number;
	topics: number;
}

const { sources, topics } = Astro.props;

const count = (num: number, singular: string, plural: string) =>
	`${num} ${num === 1 ? singular : plural}`;
---

<aside
	class={styles.drawer}
	aria-labelledby="sources-drawer-title"
>
	<a
		title="enlace hacia la página de fuentes"
		class={styles.inner}
		href="/behavior/fuentes"
	>
		{/* la pestaña de la carpeta: qué guarda, no qué número hace */}
		<h2
			class={styles.tab}
			id="sources-drawer-title"
		>
			Fuentes
		</h2>

		<p class={styles.description}>
			Este es el cajón donde guardo todas las fuentes en las que me he basado
			para escribir acerca de los topics que trato en esta sección de behavior.
		</p>

		<p class={styles.foot}>
			<span class={styles.meta}>
				{
					`${count(sources, "fuente", "fuentes")} · ${count(topics, "tema", "temas")}`
				}
			</span>
			<span class={styles.cta}>
				Entrar al cajón
				<span
					class={styles.ctaArrow}
					aria-hidden="true"
					>→</span
				>
			</span>
		</p>
	</a>
</aside>
