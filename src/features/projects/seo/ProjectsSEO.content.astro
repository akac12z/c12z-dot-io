---
import type { CollectionEntry } from "astro:content";

import { convertDateToISO8601 } from "@/utils/validatingDate";
import { SITE_DEFAULT_CONFIG } from "@/global/siteInfo";

import ContentSEO from "@/components/common/seo/ContentSEO.astro";

const { entry } = Astro.props;

const project = entry as CollectionEntry<"projects">;
const { data } = project;
const {
	cover,
	keywords,
	publishDate,
	projectTitle,
	projectDescription,
	lastTimeEdited,
} = data;

const projectName = `Proyecto: ${projectTitle}`;
const projectDesc = `${projectDescription}`;

const ogImage = cover.src?.src
	? new URL(cover.src?.src, Astro.site)
	: new URL("./og-image.png", Astro.site);
const ogImageAlt = cover.alt ? cover.alt : `imagen del proyecto ${projectName}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const justInCaseNoCoverSrc =
	`${SITE_DEFAULT_CONFIG.url}${cover.src?.src}` || ogImage;
const justInCaseNoCoverAlt = ogImageAlt || projectName;

const publisDateInISO = convertDateToISO8601(publishDate);
const lastTimeEditedInISO = lastTimeEdited ? lastTimeEdited : publisDateInISO;
---

<ContentSEO
	postName={projectName}
	postDescription={projectDesc}
	canonicalURL={canonicalURL}
	justInCaseNoCoverSrc={justInCaseNoCoverSrc}
	justInCaseNoCoverAlt={justInCaseNoCoverAlt}
	publisDateInISO={publisDateInISO}
	lastTimeEditedInISO={lastTimeEditedInISO}
	keywords={keywords}
/>
