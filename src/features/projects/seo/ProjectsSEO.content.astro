---
import type { CollectionEntry } from "astro:content";

import { convertDateToISO8601 } from "@/utils/validating-date.ts";

import ContentSEO from "@/components/common/seo/ContentSEO.astro";

const { entry } = Astro.props;

const project = entry as CollectionEntry<"projects">;
const { data, id } = project;
const {
	cover,
	keywords,
	publishDate,
	projectTitle,
	projectDescription,
	lastTimeEdited,
} = data;

const projectName = `Proyecto: ${projectTitle}`;
const projectDesc = `${projectDescription}`;

const coverAlt = cover.alt ? cover.alt : `imagen del proyecto ${projectName}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// OG dinámico generado en build time (src/pages/og/proyectos/[...id].png.ts)
const ogImageSrc = new URL(`/og/proyectos/${id}.png`, Astro.site);
const ogImageAlt = coverAlt || projectName;

const publisDateInISO = convertDateToISO8601(publishDate);
const lastTimeEditedInISO = lastTimeEdited ? lastTimeEdited : publisDateInISO;
---

<ContentSEO
	postName={projectName}
	postDescription={projectDesc}
	canonicalURL={canonicalURL}
	ogImageSrc={ogImageSrc}
	ogImageAlt={ogImageAlt}
	publisDateInISO={publisDateInISO}
	lastTimeEditedInISO={lastTimeEditedInISO}
	keywords={keywords}
/>
