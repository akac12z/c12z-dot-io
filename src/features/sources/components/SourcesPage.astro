---
/**
 * /behavior/fuentes — "el cajón": the whole drawer of sources, one folder
 * per TOPIC (a bias or a mental model), not one per source. Dense on
 * purpose: it has to scale to ~140 topics, so each folder keeps its
 * sources inside and the viewer walks through them.
 *
 * It is the only place that calls `getTopics()` for rendering; the
 * per-topic route calls the same function from `getStaticPaths`, which is
 * what keeps slugs and order in sync between the two.
 *
 * Composition: header + TerminalSearch (search + kind toggles) + a grid of
 * TopicFolder (each one carrying its own SourceSheets viewer) +
 * FolderDialogScript (the viewer behaviour, once per page).
 *
 * Filtering happens client-side in ../scripts/sources-filters.ts, over the
 * `data-*` that TopicFolder prints. Nothing is re-rendered: cells are
 * toggled with `hidden`.
 */
import styles from "./sources.module.css";

import { getTopics } from "../data/get-topics.ts";

import TopicFolder from "./TopicFolder.astro";
import FolderDialogScript from "./FolderDialogScript.astro";
import GoBackInTop from "@/components/common/ui/buttons/GoBackInTop.astro";

import TerminalSearch from "./TerminalSearch.astro";
import OwnThoughts from "@/components/common/ui/content/OwnThoughts.astro";

const topics = await getTopics();

// for the tally in the terminal panel ("N carpetas · M fuentes")
const totalSources = topics.reduce((sum, t) => sum + t.sources.length, 0);
---

<section
	class={styles.sourcesPage}
	data-sources-root
>
	<GoBackInTop
		headPage="/behavior"
		title="ir a la página de behavior"
	/>

	<header class={styles.pageHeader}>
		<h1 class={styles.title}>Las fuentes.</h1>
		<p>
			Cada una de las carpeta hace referencia a un contenido distinto que he
			subido (o subiré) en la sección de behavior, ya sea diseño, sesgos o
			modelos mentales. Cada una contine un conjunto <i>archivos</i> que hacen referencia
			a las distintas fuentes que he usado para aprender y escribir sobre el tema.
		</p>
		<p>
			Este lugar existe porque a mí me costó mucho encontrar dónde aprender
			sobre <i>behavioral economics</i>, ya que no es algo que se enseñe fácilmente.
			Si te interesa entender por qué nos comportamos como lo hacemos, y cómo puedes
			aplicarlo a producto (o cómo lo aplican contigo), quizá aquí encuentres por
			dónde empezar.
		</p>
	</header>
	<TerminalSearch
		topics={topics}
		totalSources={totalSources}
	/>

	{
		topics.length > 0 ? (
			<>
				<ul class={styles.topicGrid}>
					{topics.map((topic) => (
						<TopicFolder topic={topic} />
					))}
				</ul>
				<p
					class={styles.noResults}
					data-no-results
					hidden
				>
					Nada en el cajón con esos filtros.
				</p>
			</>
		) : (
			<p>El cajón está vacío. Pronto habrá material. 🙂</p>
		)
	}

	<FolderDialogScript />
</section>

<script>
	import { initSourcesFilters } from "../scripts/sources-filters.ts";

	initSourcesFilters();
	document.addEventListener("astro:page-load", initSourcesFilters);
</script>
