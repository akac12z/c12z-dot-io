---
/**
 * Loads the viewer behaviour: opens a folder's <dialog> and walks through
 * its sources like a slider (‹ ›, arrow keys and Esc). No framework, no
 * client state.
 *
 * Include it once per page that renders SourceSheets. Including it twice
 * is harmless: the listener is delegated to `document` and guarded by a
 * flag, so it only registers once (see ../scripts/folder-dialog.ts).
 */
---

<script>
	import { initFolderDialog } from "../scripts/folder-dialog.ts";

	initFolderDialog();
</script>
