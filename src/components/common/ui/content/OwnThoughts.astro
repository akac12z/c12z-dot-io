---
import styles from "./ownThoughts.module.css";
import UnclearThought from "../icons/UnclearThought.astro";

interface Props {
	paragraphs: string[];
	asset?: boolean;
	title_asset?: string;
	href_link?: string;
	title_link?: string;
}

const { paragraphs, asset, title_asset, title_link, href_link } = Astro.props;
---

<section class={`${styles.otSection}`}>
	<section class={`${styles.otGrid}`}>
		<UnclearThought />
		<section class={`${styles.otBody}`}>
			{paragraphs.map((paragraph) => <p class={styles.otText}>{paragraph}</p>)}
			{
				asset && (
					<section class={styles.otAsset}>
						<a
							class={`lettering ${styles.otLink}`}
							target="_blank"
							rel="noopener noreferrer"
							title={title_link}
							href={href_link}
						>
							{title_asset}
						</a>
					</section>
				)
			}
		</section>
	</section>
</section>
