---
/**
 * OwnThoughts
 *
 * Callout box for inline editorial notes within content (essays, book reviews, etc.).
 * Renders an icon + one or more body paragraphs, with an optional external link asset.
 *
 * Props:
 *   paragraphs   string[]   — Body copy. Each string becomes its own <p>.
 *   asset?       boolean    — Show the link block below the paragraphs.
 *   title_asset? string     — Visible label of the link (anchor text).
 *   href_link?   string     — URL the link points to.
 *   title_link?  string     — Tooltip / accessible title for the <a>.
 *
 * Usage (en MDX):
 *   only one paragraphs
 *   <OwnThoughts paragraphs={["your thought"]} />
 *
 *   some paragraphs — each string[] is render in its own <p>
 *   <OwnThoughts paragraphs={["First paragraph.", "second paragraphs.", "..."]} />
 *
 *   with links (assets, internal or external)
 *   <OwnThoughts
 *     paragraphs={["thoughts.", "thoughts", "..."]}
 *     asset
 *     title_asset="Ver fuente"
 *     href_link="https://example.com"
 *     title_link="Fuente original"
 *   />
 *
 * Notes:
 *   - `asset`, `title_asset`, `href_link`, and `title_link` must all be provided
 *     together; the link renders only when `asset` is truthy.
 *   - In MDX files, import the component after the frontmatter and before any content:
 *       import OwnThoughts from "../../../components/common/ui/content/OwnThoughts.astro"; or
 * 			 import OwnThoughts from "@/components/common/ui/content/OwnThoughts.astro";
 */

import styles from "./ownThoughts.module.css";
import UnclearThought from "../icons/UnclearThought.astro";

interface Props {
	paragraphs: string[];
	asset?: boolean;
	title_asset?: string;
	href_link?: string;
	title_link?: string;
}

const { paragraphs, asset, title_asset, title_link, href_link } = Astro.props;
---

<section class={`${styles.otSection}`}>
	<section class={`${styles.otGrid}`}>
		<UnclearThought />
		<section class={`${styles.otBody}`}>
			{paragraphs.map((paragraph) => <p class={styles.otText}>{paragraph}</p>)}
			{
				asset && (
					<section class={styles.otAsset}>
						<a
							class={`lettering ${styles.otLink}`}
							target="_blank"
							rel="noopener noreferrer"
							title={title_link}
							href={href_link}
						>
							{title_asset}
						</a>
					</section>
				)
			}
		</section>
	</section>
</section>
