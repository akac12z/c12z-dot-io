---
import styles from "./inc.module.css";
import { Image } from "astro:assets";

// Define props interface (inline for simplicity; consider moving to a separate .ts file for reusability)
interface Props {
	src: any;
	alt: string;
	caption: string;
}

const { src, alt, caption } = Astro.props as Props;
---

<div class={styles.inc}>
	<Image
		src={src}
		alt={alt}
		loading="lazy"
		class={styles.theImage}
	/>
	<p class={styles.theCaption}>
		{caption}
	</p>
</div>
