---
import styles from "./link.module.css";

interface Props {
	title_asset: string;
	href_link: string;
	title_link: string;
}

const { title_asset, title_link, href_link } = Astro.props;
---

<div>
	<a
		class={styles.link}
		target="_blank"
		rel="noopener noreferrer"
		title={title_link}
		href={href_link}
	>
		{title_asset}
	</a>
</div>
