---
import styles from "./link.module.css"
import GoOut from "@/icons/GoOut.astro";

interface Props {
  title_asset: string;
  href_link: string;
  title_link: string;
  is_third_party?: boolean;
}

const { title_asset, title_link, href_link, is_third_party } = Astro.props;
---

<div>
  <a
    class={styles.link}
    target="_blank"
    rel="noopener noreferrer"
    title={title_link}
    href={href_link}
  >
    {title_asset} {is_third_party && <GoOut />}
  </a>
</div>

