---
import styles from "./gbit.module.css"

interface Props {
  headPage: string;
  title?: string;
}

const { headPage, title } = Astro.props;

if (!headPage.startsWith("/")) {
  throw new Error(
    `Invalid href: "${headPage}". The href must start with a "/".`,
  );
}
---

<a title={title} href={headPage} class={styles.gbit}> ← Atrás </a>
