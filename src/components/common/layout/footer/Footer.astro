---
import SocialBlock from "@/components/common/ui/icons/social/SocialBlock.astro";
import { SITE_VERSION } from "@/global/siteInfo";
---

<footer class="flex flex-col items-center footer">
  <hr class="pb-3 h-px w-3/4 text-cz-text-headers-dark/50" />
  <section class="flex items-center justify-between w-full">
    <p class="text-xs self-start">
      with 🖤 - <a
        class="text-cz-primary"
        href="/contexto"
        title="Contexto de Chema Ferréndez - c12z">chema</a
      >
    </p>

    <section class="flex items-center justify-between gap-3">
      <SocialBlock />
      <span class="hidden xs:block font-pixel text-xxs tracking-widest text-cz-text-relax-dark border border-cz-border-dark rounded px-2 py-0.5">
        {SITE_VERSION} · main
      </span>

    </section>
  </section>

</footer>
